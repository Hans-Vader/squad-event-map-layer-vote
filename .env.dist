# Required: Discord Bot Token
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Optional: Bot-level superadmin IDs (comma-separated, bypass all checks)
# ADMIN_IDS=123456789,987654321

# Optional: Debug logging
# DEBUG_MODE=true

# Optional: Custom layer data source URL
# LAYERS_JSON_URL=https://raw.githubusercontent.com/fantinodavide/SquadLayerList/refs/heads/main/layers.json

# Docker user/group ID
PUID=1000
PGID=1000
