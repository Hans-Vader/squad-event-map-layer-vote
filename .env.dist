# Required: Discord Bot Token
DISCORD_BOT_TOKEN=YOUR_TOKEN

# Optional: Bot-level superadmin IDs (comma-separated, bypass all checks)
# ADMIN_IDS=123456789,987654321

# Optional: Debug logging
# DEBUG_MODE=true

# Optional: Custom layer data source URL(s)
# Accepts a single URL, a comma-separated list, or a JSON array.
# When the same rawName appears in multiple sources, the source listed later wins.
#   Single:   LAYERS_JSON_URL=https://a.com/layers.json
#   List:     LAYERS_JSON_URL=https://a.com/x.json,https://b.com/y.json
#   JSON:     LAYERS_JSON_URL=["https://a.com/x.json","https://b.com/y.json"]
LAYERS_JSON_URL=["https://raw.githubusercontent.com/fantinodavide/SquadLayerList/refs/heads/main/layers.json","https://raw.githubusercontent.com/fantinodavide/SquadLayerList/refs/heads/main/layers.json"]

# Docker user/group ID
PUID=1000
PGID=1000
